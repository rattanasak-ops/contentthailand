# ContentThailand — Environment Variables
# Copy this file to .env.local for development

# ─── Database ────────────────────────────────
DATABASE_URL=postgresql://ct_user:ct_pass_local@localhost:5432/contentthailand
POSTGRES_PASSWORD=ct_pass_local

# ─── Next.js ─────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Strapi ──────────────────────────────────
STRAPI_APP_KEYS=key1,key2,key3,key4
STRAPI_API_TOKEN_SALT=your-api-token-salt
STRAPI_ADMIN_JWT_SECRET=your-admin-jwt-secret
STRAPI_JWT_SECRET=your-jwt-secret

# ─── Redis ───────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Production Only ─────────────────────────
SITE_URL=https://contentthailand.com
